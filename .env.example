# ============================================
# Variables d'environnement — ESDEA Consulting
# ============================================
# Copiez ce fichier en ".env" et remplissez les valeurs.
# Le fichier .env NE DOIT JAMAIS être commité (il est dans .gitignore).
#
# En production, ces variables se configurent dans
# le dashboard Vercel : Settings > Environment Variables
# ============================================

# Clé API Resend (pour l'envoi des mails du formulaire de contact)
# Créez un compte gratuit sur https://resend.com et générez une clé.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Adresse qui reçoit les messages du formulaire de contact
CONTACT_TO_EMAIL=contact@esdeaconsulting.fr

# Adresse d'expéditeur (doit être un domaine vérifié sur Resend)
CONTACT_FROM_EMAIL=site@esdeaconsulting.fr
